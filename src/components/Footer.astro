<!-- Site Footer (Audit #2, #13) -->
<footer class="site-footer" id="contact">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__cta">
        <h2 class="site-footer__heading">Let's make designs that help people</h2>
        <p class="site-footer__text">Always open to new connections, engaging conversation, and opportunities in the accessibility and education space!</p>
        <div class="site-footer__links">
          <a
            href="mailto:lidia.ochoa@uxbylidiaochoa.com?subject=Contact%20regarding%20portfolio"
            class="site-footer__link"
            style="background: var(--color-teal);"
            aria-label="Email Lidia to connect (opens email client)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Let's Connect
          </a>
          <a
            href="https://www.linkedin.com/in/lidia-ochoa/"
            class="site-footer__link"
            style="background: var(--color-mauve);"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Connect with Lidia on LinkedIn (opens in new tab)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
          <a
            href="https://github.com/lidsocho"
            class="site-footer__link"
            style="background: #e8e8e8;"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="View Lidia's GitHub profile (opens in new tab)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            GitHub
          </a>
        </div>
      </div>
      <form class="contact-form" action="https://api.web3forms.com/submit" method="POST" aria-labelledby="contact-form-heading">
        <input type="hidden" name="access_key" value="b71c27b3-6dc4-4355-95d6-f917e93ca374" />
        <input type="hidden" name="subject" value="New contact from UXbyLidiaOchoa.com" />
        <input type="checkbox" name="botcheck" style="display:none" aria-hidden="true" tabindex="-1" />
        <h3 id="contact-form-heading" class="contact-form__heading">Send a message</h3>
        <div class="contact-form__field">
          <label for="contact-name" class="contact-form__label">Name</label>
          <input type="text" id="contact-name" name="name" required autocomplete="name" class="contact-form__input" />
        </div>
        <div class="contact-form__field">
          <label for="contact-email" class="contact-form__label">Email</label>
          <input type="email" id="contact-email" name="email" required autocomplete="email" class="contact-form__input" />
        </div>
        <div class="contact-form__field">
          <label for="contact-message" class="contact-form__label">Message</label>
          <textarea id="contact-message" name="message" rows="4" required class="contact-form__input contact-form__textarea"></textarea>
        </div>
        <button type="submit" class="contact-form__submit">
          Send Message
          <span aria-hidden="true">&rarr;</span>
        </button>
        <p class="contact-form__success" aria-live="polite" hidden>Thank you for your message! I will get back to you very soon.</p>
        <p class="contact-form__error" aria-live="assertive" hidden>Something went wrong. Please try again.</p>
        <noscript><p class="contact-form__error" style="margin-top:1rem">This form requires JavaScript. You can reach me directly at <a href="mailto:lidia.ochoa@uxbylidiaochoa.com">lidia.ochoa@uxbylidiaochoa.com</a>.</p></noscript>
      </form>
    </div>
    <div class="site-footer__divider"></div>
    <div class="site-footer__bottom">
      <p>&copy; 2026 UXbyLidiaOchoa. All rights reserved.</p>
      <p>Designed by Lidia Ochoa</p>
    </div>
  </div>
</footer>

<script>
  const form = document.querySelector('.contact-form');
  const successMsg = form.querySelector('.contact-form__success');
  const errorMsg = form.querySelector('.contact-form__error');
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg.hidden = true;
    errorMsg.hidden = true;
    const btn = form.querySelector('.contact-form__submit');
    btn.disabled = true;
    btn.textContent = 'Sending…';
    const res = await fetch(form.action, {
      method: 'POST',
      body: new FormData(form),
    });
    if (res.ok) {
      form.reset();
      successMsg.hidden = false;
      btn.disabled = false;
      btn.innerHTML = 'Send Message <span aria-hidden="true">&rarr;</span>';
    } else {
      btn.disabled = false;
      btn.innerHTML = 'Send Message <span aria-hidden="true">&rarr;</span>';
      errorMsg.hidden = false;
    }
  });
</script>
