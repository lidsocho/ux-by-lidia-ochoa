<!-- Site Footer (Audit #2, #13) -->
<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="site-footer__grid">
      <div class="site-footer__cta">
        <h2 class="site-footer__heading">Let's make designs that help people</h2>
        <p class="site-footer__text">Always open to new connections, engaging conversation, and opportunities in the accessibility and education space!</p>
        <div class="site-footer__links">
          <a
            href="mailto:lidia.ochoa@uxbylidiaochoa.com?subject=Contact%20regarding%20portfolio"
            class="site-footer__link"
            style="background: var(--color-teal);"
            aria-label="Email Lidia to connect (opens email client)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Let's Connect
          </a>
          <a
            href="https://www.linkedin.com/in/lidia-ochoa/"
            class="site-footer__link"
            style="background: var(--color-mauve);"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Connect with Lidia on LinkedIn (opens in new tab)"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
      <form class="contact-form" action="https://formspree.io/f/placeholder" method="POST" aria-labelledby="contact-form-heading">
        <h3 id="contact-form-heading" class="contact-form__heading">Send a message</h3>
        <div class="contact-form__field">
          <label for="contact-name" class="contact-form__label">Name</label>
          <input type="text" id="contact-name" name="name" required autocomplete="name" class="contact-form__input" />
        </div>
        <div class="contact-form__field">
          <label for="contact-email" class="contact-form__label">Email</label>
          <input type="email" id="contact-email" name="email" required autocomplete="email" class="contact-form__input" />
        </div>
        <div class="contact-form__field">
          <label for="contact-message" class="contact-form__label">Message</label>
          <textarea id="contact-message" name="message" rows="4" required class="contact-form__input contact-form__textarea"></textarea>
        </div>
        <button type="submit" class="contact-form__submit">
          Send Message
          <span aria-hidden="true">&rarr;</span>
        </button>
      </form>
    </div>
    <div class="site-footer__divider"></div>
    <div class="site-footer__bottom">
      <p>&copy; 2025 UXbyLidiaOchoa. All rights reserved.</p>
      <p>Designed by Lidia Ochoa</p>
    </div>
  </div>
</footer>
