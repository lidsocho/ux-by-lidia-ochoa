---
import SkipLink from '../components/SkipLink.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  projectColor?: string;
}

const { title, description = 'UX/Product Designer specializing in accessible learning and financial tools.', projectColor } = Astro.props;

// Compute a static color-mix fallback (10% project color on #fafafa) at build time
function mixFallback(hex: string): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  const bg = 0xfa; // #fafafa
  const mix = (c: number) => Math.round(c * 0.1 + bg * 0.9).toString(16).padStart(2, '0');
  return `#${mix(r)}${mix(g)}${mix(b)}`;
}
const cardBgFallback = projectColor ? mixFallback(projectColor) : undefined;

// Mute a hex color for dark mode (reduce brightness by ~20%)
function mutedColor(hex: string): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  const mute = (c: number) => Math.round(c * 0.8).toString(16).padStart(2, '0');
  return `#${mute(r)}${mute(g)}${mute(b)}`;
}
const projectColorDark = projectColor ? mutedColor(projectColor) : undefined;
const cardBgFallbackDark = projectColorDark ? mixFallback(projectColorDark) : undefined;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://uxbylidiaochoa.com${Astro.url.pathname}`} />
  <meta property="og:image" content="https://uxbylidiaochoa.com/images/lidia-profile.png" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://uxbylidiaochoa.com/images/lidia-profile.png" />
  {projectColorDark && (
    <style set:html={`
      @media (prefers-color-scheme: dark) {
        #main-content {
          --color-project: ${projectColorDark} !important;
          --color-card-tint: ${projectColorDark} !important;
          --color-card-bg: ${cardBgFallbackDark} !important;
          --color-card-bg: color-mix(in srgb, ${projectColorDark} 10%, var(--color-bg)) !important;
        }
      }
    `} />
  )}
  <link rel="icon" type="image/svg+xml" href="/images/logo.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@400;600;700&family=Commissioner:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
  <SkipLink />
  <Header />
  <main id="main-content" style={projectColor ? `--color-project: ${projectColor}; --color-card-tint: ${projectColor}; --color-card-bg: ${cardBgFallback}; --color-card-bg: color-mix(in srgb, ${projectColor} 10%, var(--color-bg));` : undefined}>
    <slot />
  </main>
  <Footer />
  <script src="/scripts/reveal.js" is:inline></script>
</body>
</html>
