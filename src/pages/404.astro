---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found — UX by Lidia Ochoa">
  <section class="section">
    <div class="container" style="text-align: center; padding-block: var(--space-2xl);">
      <h1 style="font-size: clamp(3rem, 8vw, 6rem); margin-bottom: var(--space-sm);">404</h1>
      <p style="font-size: 1.25rem; color: var(--color-text-secondary); margin-bottom: var(--space-lg);">This page doesn't exist, but there's plenty to explore.</p>
      <a href="/" class="hero__cta" style="display: inline-block;">
        Back to projects
        <span aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </section>
</BaseLayout>
