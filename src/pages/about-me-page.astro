---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="About Me — Lidia Ochoa | UX/Product Designer" description="UX & Product Designer specializing in accessibility and inclusive design. Seven years as an educator and assistive-technology practitioner, turning deep user research into WCAG 2.2 AA–conformant products — from AAC apps to design systems. Native Spanish speaker, adept at cross-cultural research.">
  <!-- About Hero (Audit #3 — h1) -->
  <section class="section" aria-labelledby="about-hero-heading">
    <div class="container">
      <div class="about-hero reveal">
        <div>
          <h1 id="about-hero-heading">Hi, I'm Lidia</h1>
          <p class="mt-md">I didn't come to accessibility through UX — I came to UX through accessibility. After 7 years teaching math and working closely with autistic, disabled, and neurodivergent students, I now design WCAG 2.2 AA–conformant products that remove the barriers I watched my students hit every day. Native Spanish speaker, adept at cross-cultural research.</p>
          <div class="recent-wins mt-md">
            <div class="recent-win recent-win--orange">
              <span class="recent-win__label">Recent Win #1</span>
              140% boost in EOC pass rates<span class="recent-win__sub">Inclusive, data-informed instruction at Bob Hope HS</span>
            </div>
            <div class="recent-win recent-win--teal">
              <span class="recent-win__label">Recent Win #2</span>
              9.8× increase in communication usage<span class="recent-win__sub">ComBoard AAC tool for a disabled student</span>
            </div>
            <div class="recent-win" style="background: #faf9f6; border: 2px solid var(--color-shadow); border-right-width: 4px; border-bottom-width: 4px;">
              <span class="recent-win__label">Location</span>
              Seattle, WA<span class="recent-win__sub">Open to remote &amp; hybrid</span>
            </div>
          </div>
        </div>
        <div class="about-hero__image about-hero__image--circle">
          <img
            src="/images/lidia-ruins-crop.jpg"
            alt="Lidia grins while peeking through a stone opening at a desert ruins site."
            loading="eager"
            width="800"
            height="800"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Core Skills -->
  <section class="section" aria-labelledby="core-skills-heading">
    <div class="container">
      <h2 id="core-skills-heading" class="reveal">Core Skills</h2>
      <h3 class="reveal">What I Do</h3>
      <ul class="skills-list reveal" role="list">
        <li class="skill-tag">User Research</li>
        <li class="skill-tag">Wireframing</li>
        <li class="skill-tag">Prototyping</li>
        <li class="skill-tag">Usability Testing</li>
        <li class="skill-tag">Information Architecture</li>
        <li class="skill-tag">Journey Mapping</li>
        <li class="skill-tag">Personas</li>
        <li class="skill-tag">Affinity Mapping</li>
        <li class="skill-tag">Inclusive Design</li>
        <li class="skill-tag">Responsive Design Systems</li>
        <li class="skill-tag">Accessibility (WCAG 2.2)</li>
        <li class="skill-tag">Visual Design</li>
      </ul>
      <h3 class="reveal">Tools</h3>
      <ul class="skills-list reveal" role="list">
        <li class="skill-tag">Figma</li>
        <li class="skill-tag">Webflow</li>
        <li class="skill-tag">Astro</li>
        <li class="skill-tag">HTML/CSS</li>
        <li class="skill-tag">Miro</li>
        <li class="skill-tag">Adobe Suite</li>
        <li class="skill-tag">WCAG Audits</li>
      </ul>
    </div>
  </section>

  <!-- My Story -->
  <section class="section" aria-labelledby="my-story-heading">
    <div class="container">
      <h2 id="my-story-heading" class="reveal">My Story</h2>

      <!-- The Moment I Noticed -->
      <div class="story-section reveal">
        <div>
          <h3>The Moment I Noticed</h3>
          <p class="mt-sm">In my fourth year teaching, I met a nonspeaking student with cerebral palsy who had rejected every AAC device. They exhausted her, blocked her face, and weren't designed for her — just for the average user. Working with her and her family to co-create a communication tool became the most meaningful work of my teaching career. That effort became ComBoard, a personalized AAC tool that achieved a 9.8× increase in communication usage vs. her prior tools.</p>
          <p>That experience changed how I saw every tool, every interface. I started noticing who was being left out — in assistive technology, in learning software, in finance tools. The defaults are not working for everyone.</p>
        </div>
        <div class="story-section__image">
          <img
            src="/images/about/classroom.jpg"
            alt="Four students sitting at desks using Chromebooks, graphing calculators, and whiteboards in a classroom setting."
            loading="lazy"
            width="2095"
            height="2095"
          />
        </div>
      </div>

      <!-- The Shift -->
      <div class="story-section story-section--reverse reveal">
        <div>
          <h3>The Shift</h3>
          <p class="mt-sm">I started learning UX the way I teach — by doing. I conducted user interviews, built affinity maps, ran usability studies, and iterated on wireframes and prototypes in Figma. Along the way, I earned Google's UX Design Professional Certificate, which formalized the methods I was already practicing. But the foundation — designing <em>with</em> the people you're designing <em>for</em> — came from the classroom.</p>
        </div>
        <div class="story-section__image">
          <img
            src="/images/about/affinity-map.png"
            alt="An affinity map created in Miro showing clustered sticky notes from a usability study."
            loading="lazy"
            width="1972"
            height="1362"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- What I'm Looking For -->
  <section class="section" aria-labelledby="looking-for-heading">
    <div class="container">
      <div class="looking-for reveal">
        <div class="looking-for__right">
          <img
            src="/images/about/lidia-gallery.jpg"
            alt="Lidia smiles in a black blazer at her Our Light Unbound art exhibition."
            class="looking-for__photo"
            loading="lazy"
            width="800"
            height="800"
          />
          <a href="#contact" class="hero__cta">
            Let's talk
            <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
        <div class="looking-for__text">
          <h2 id="looking-for-heading">What I'm Looking For</h2>
          <p class="mt-sm">I'm looking for a product design role where accessibility is part of the design culture. I do my best work on teams that value research, care about the people they're building for, and give designers room to advocate for inclusive solutions.</p>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
