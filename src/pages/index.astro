---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---
<BaseLayout title="UX by Lidia Ochoa — UX/Product Designer">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner reveal">
        <div class="hero__content">
          <h1 class="hero__title">UX/Product Designer | A11y &amp; Learning Tools</h1>
          <p class="hero__subtitle">I use my 7 years of classroom experience and work with diverse learners to design research-backed products that remove barriers to financial and academic growth for disabled and neurodivergent individuals.</p>
          <p class="hero__meta" style="color: var(--color-text-secondary); font-weight: 600; margin-top: 0.5rem;">Visual &amp; marketing design &middot; UX &middot; Bilingual (EN/ES)</p>
          <a href="#projects" class="hero__cta">
            see my work
            <span class="hero__cta-arrow bouncy" aria-hidden="true">&darr;</span>
          </a>
        </div>
        <div class="hero__photo">
          <img
            src="/images/lidia-profile.png"
            alt="Lidia smiles, wearing a mustard yellow cardigan and reclining on a bright orange park bench."
            class="hero__photo-img"
            width="1130"
            height="1622"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section (Audit #3, #12) -->
  <section class="section" id="projects" aria-labelledby="projects-heading">
    <div class="container">
      <h2 id="projects-heading" class="mb-md reveal">Recent projects showcasing design thinking, accessibility, learning, and financial tools.</h2>
      <ul class="projects-grid" role="list">
        <ProjectCard
          image="/images/home/comboard-thumb.png"
          alt="A circle with several augmentative alternative communication board screens"
          date="4/24 - 9/25"
          role="UXR & Design"
          title="ComBoard"
          description="ETRAN inspired keyboard reduced eye strain & increased independent spelling by 980%"
          href="/comboard-app"
          accentColor="var(--color-teal)"
        />
        <ProjectCard
          image="/images/home/budget-thumb.png"
          alt="Circle with mint background featuring several devices with a budget app prototype displayed"
          date="2/25 - 6/25"
          role="UXR & Design"
          title="Budget App"
          description="Case study: Research-backed, WCAG-2.2 aligned app that makes it easy to start and stick to a budget"
          href="/budgetapp"
          accentColor="var(--color-green)"
        />
        <ProjectCard
          image="/images/home/our-light-thumb.png"
          alt="Our Light Unbound exhibition branding — the wordmark and twilight-gradient promotional flyers, social graphics, and event collateral"
          date="12/25 - 1/26"
          role="Brand & Campaign Design"
          title="Our Light Unbound"
          description="Brand identity and full promotional campaign — flyers, social graphics, and event collateral — for a month-long community art exhibition"
          href="/our-light-unbound"
          accentColor="var(--color-mauve)"
        />
        <ProjectCard
          image="/images/home/synology-thumb.png"
          alt="Synology LATAM concept campaign — dark social media square featuring the DiskStation DS124 with Spanish headline 'Tu trabajo, siempre seguro'"
          date="6/26"
          role="Marketing Design"
          title="Synology LATAM Campaign"
          description="Concept bilingual mini-campaign — adapting the same creative across Spanish and English for Synology's DiskStation DS124"
          href="/synology-campaign"
          accentColor="#2684FF"
        />
        <ProjectCard
          image="/images/home/offline-budget-thumb.png"
          alt="Two-panel composite showing Bb Budget: transaction import interface and income vs spending trend charts"
          date="10/25 - 3/26"
          role="Design & Dev"
          title="Bb Budget"
          description="Shipped tool: A privacy-first budgeting tool that automates the tedious parts of tracking finances while keeping the user in control"
          href="/offline-budget"
          accentColor="var(--color-teal)"
        />
      </ul>
    </div>
  </section>

  <!-- About Me Preview -->
  <section class="section" id="about-preview" aria-labelledby="about-preview-heading">
    <div class="container" style="text-align: center;">
      <div class="reveal">
        <h2 id="about-preview-heading">About Me</h2>
        <p class="mt-sm" style="max-width: 480px; margin-inline: auto; color: var(--color-text-secondary);">UX/Product designer in Seattle, WA specializing in accessible learning and financial tools.</p>
        <a href="/about-me-page" class="about-preview__cta mt-md">
          Learn more about Lidia
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
