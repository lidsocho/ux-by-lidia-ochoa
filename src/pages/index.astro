---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
---
<BaseLayout title="UX by Lidia Ochoa — UX/Product Designer">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner reveal">
        <div class="hero__content">
          <h1 class="hero__title">UX/Product Designer</h1>
          <p class="hero__subtitle">Accessibility-focused UX designer with 7 years in education. I design inclusive products that work for everyone — especially learners and users who've been overlooked.</p>
          <p class="hero__meta" style="color: var(--color-text-secondary); font-weight: 600; margin-top: 0.5rem;">Looking for roles in UX, EdTech, A11y, and design</p>
          <a href="#projects" class="hero__cta">
            see my work
            <span class="hero__cta-arrow bouncy" aria-hidden="true">&darr;</span>
          </a>
        </div>
        <div class="hero__photo">
          <img
            src="/images/lidia-profile.png"
            alt="Lidia smiles, wearing a mustard yellow cardigan and reclining on a bright orange park bench."
            class="hero__photo-img"
            width="1130"
            height="1622"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Projects Section (Audit #3, #12) -->
  <section class="section" id="projects" aria-labelledby="projects-heading">
    <div class="container">
      <h2 id="projects-heading" class="mb-md reveal">Recent Projects</h2>
      <ul class="projects-grid" role="list">
        <ProjectCard
          image="/images/home/Frame 6.png"
          alt="ComBoard AAC app on an iPad — colorful letter-group keyboard with Speak, Listen, and Clear buttons, smart suggestions, and Yes/No quick responses on an orange background"
          date="4/24 - 9/25"
          role="UXR & Design"
          title="ComBoard"
          description="Custom AAC app for a non-speaking student with cerebral palsy — 9.8× increase in communication usage vs. prior tools"
          href="/comboard-app"
          accentColor="#f28c28"
        />
        <ProjectCard
          image="/images/home/Frame 2.png"
          alt="Budget App dashboard on an iPhone — donut chart showing income vs expenses, linked bank accounts, savings and retirement totals, and budget goals on a green background"
          date="2/25 - 6/25"
          role="UXR & Design"
          title="Budget App"
          description="Accessible budgeting app for novice and visually impaired users, validated through usability testing and competitive analysis"
          href="/budgetapp"
          accentColor="var(--color-green)"
        />
        <ProjectCard
          image="/images/home/Frame 7.png"
          alt="Our Light Unbound exhibit ad — landscape format with the wordmark, mission statement, exhibition dates, venue, QR code, and 4Culture logo on a mauve background"
          date="12/25 - 1/26"
          role="Brand & Campaign Design"
          title="Our Light Unbound"
          description="Brand identity and promotional campaign for a month-long community art exhibition with 1,000+ opening night visitors"
          href="/our-light-unbound"
          accentColor="var(--color-mauve)"
        />
        <ProjectCard
          image="/images/home/Frame 8.png"
          alt="Synology LATAM concept campaign — dark social media square featuring the DiskStation DS124 with Spanish headline 'Tu trabajo, siempre seguro' on a blue background"
          date="6/26"
          role="Marketing Design"
          title="Synology LATAM Campaign"
          description="Concept bilingual mini-campaign adapting the same creative across Spanish and English for Synology's DiskStation DS124"
          href="/synology-campaign"
          accentColor="#2684FF"
        />
        <ProjectCard
          image="/images/home/offline-budget-thumb.png"
          alt="Bb Budget cloud version on a laptop — Trends tab showing Income vs Spending bar chart, household member sidebar, and net income area chart"
          date="10/25 - Present"
          role="Design & Dev"
          title="Bb Budget"
          description="Shipped budgeting tool I use daily — from offline prototype to multi-user cloud platform with bank integration and encryption"
          href="/offline-budget"
          accentColor="var(--color-teal)"
        />
      </ul>
    </div>
  </section>

  <!-- About Me Preview -->
  <section class="section" id="about-preview" aria-labelledby="about-preview-heading">
    <div class="container" style="text-align: center;">
      <div class="reveal">
        <h2 id="about-preview-heading">About Me</h2>
        <p class="mt-sm" style="max-width: 480px; margin-inline: auto; color: var(--color-text-secondary);">UX/Product designer in Seattle, WA specializing in accessible learning and financial tools.</p>
        <a href="/about-me-page" class="about-preview__cta mt-md">
          Learn more about Lidia
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
