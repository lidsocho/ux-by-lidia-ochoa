---
import BaseLayout from '../layouts/BaseLayout.astro';
import SideNav from '../components/SideNav.astro';
import PrevNextNav from '../components/PrevNextNav.astro';

const sections = [
  { id: 'overview', label: 'Overview' },
  { id: 'design-decisions', label: 'Design Decisions' },
  { id: 'the-work', label: 'The Work' },
  { id: 'reflection', label: 'Reflection' },
];
---
<BaseLayout title="Synology LATAM Concept Campaign — Marketing Design | Lidia Ochoa" description="A concept bilingual mini-campaign for Synology's DS124 NAS — adapting the same creative across Spanish and English while maintaining brand consistency." projectColor="#2684FF" ogImage="/images/home/synology-thumb.png">

  <!-- Hero -->
  <section class="case-hero">
    <div class="container">
      <div class="reveal">
        <h1>Synology LATAM Campaign</h1>
        <dl class="case-hero__meta">
          <div class="case-hero__meta-item"><dt>Timeline:</dt><dd>Jun 2026 (concept)</dd></div>
          <div class="case-hero__meta-item"><dt>Role:</dt><dd>Marketing Design &amp; Localization</dd></div>
          <div class="case-hero__meta-item"><dt>Tools:</dt><dd>Figma</dd></div>
        </dl>
        <div class="case-hero__tagline-row">
          <p class="case-hero__tagline">A concept bilingual mini-campaign for Synology's DiskStation DS124 — adapting the same creative across Spanish and English while keeping brand consistency, proving I don't just translate, I adapt design and message for the LATAM audience.</p>
          <p class="concept-note">Concept project — not affiliated with Synology.</p>
        </div>
      </div>
      <div class="synology-hero-assets reveal">
        <div class="mock-watermark"><img src="/images/synology/social-square-es.png" alt="Synology LATAM social media square in Spanish — dark background, DS124 product photo, headline 'Tu trabajo, siempre seguro' with blue accent text, and a 'Mas informacion' CTA button" class="synology-hero-assets__square" /></div>
        <div class="mock-watermark"><img src="/images/synology/web-banner-es.png" alt="Synology LATAM web banner in Spanish — landscape format featuring the DS124, headline 'Almacenamiento que crece contigo' with feature icons for remote access, smart backup, and cloud sync" class="synology-hero-assets__banner" /></div>
      </div>
    </div>
  </section>

  <div class="case-body">
    <SideNav sections={sections} />
    <div class="case-sections">

      <!-- Overview -->
      <section class="case-section section" id="overview" aria-labelledby="overview-heading">
        <div class="container">
          <h2 id="overview-heading" class="case-section__heading reveal">Overview</h2>
          <p class="reveal">I created a concept bilingual mini-campaign for a Synology LATAM product to demonstrate how I'd approach localized marketing design. The campaign targets the DiskStation DS124, a prosumer/SMB NAS device, with assets designed for Instagram, Facebook, LinkedIn, and web use.</p>
          <div class="problem-statement reveal">The core challenge: how do you adapt a single creative across two languages and multiple formats while maintaining brand consistency, respecting the target audience's cultural context, and following Synology's established design language?</div>

          <div class="goals-frustrations-banner reveal">
            <div class="goals-frustrations-banner__inner">
              <div>
                <h3>Goals</h3>
                <ul class="styled-list">
                  <li>Demonstrate bilingual (EN/ES) marketing design at a professional level</li>
                  <li>Maintain visual and tonal consistency across languages and formats</li>
                  <li>Follow Synology's actual brand guidelines — typography, color, logo usage, product naming</li>
                  <li>Adapt messaging to match the DS124's real professional positioning</li>
                </ul>
              </div>
              <div>
                <h3>Constraints</h3>
                <ul class="styled-list">
                  <li>Concept work — no access to internal brand assets or style guides beyond what's public</li>
                  <li>Must clearly read as unofficial/concept, not imply Synology endorsement</li>
                  <li>All copy adapted (not just translated) for natural LATAM Spanish</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Design Decisions -->
      <section class="case-section section" id="design-decisions" aria-labelledby="design-decisions-heading">
        <div class="container">
          <h2 id="design-decisions-heading" class="case-section__heading reveal">Design Decisions</h2>

          <h3 class="reveal">Brand research</h3>
          <p class="reveal">Before designing, I audited Synology's public brand presence to reverse-engineer their design language.</p>
          <div class="decisions-grid reveal">
            <div class="decision-card">
              <p class="decision-card__response"><strong>Dark aesthetic:</strong> Synology's website and marketing use deep blacks (#0B0D10) and dark backgrounds, creating a tone of security and sophistication — not the navy gradients common in generic tech marketing.</p>
            </div>
            <div class="decision-card">
              <p class="decision-card__response"><strong>Typography:</strong> Inter is used across their web presence — clean, professional, highly legible at small sizes. Not the rounder/heavier Poppins that many tech brands default to.</p>
            </div>
            <div class="decision-card">
              <p class="decision-card__response"><strong>Brand blue:</strong> Their signature accent blue appears consistently across CTAs and highlights. I matched this exactly from their site rather than approximating.</p>
            </div>
            <div class="decision-card">
              <p class="decision-card__response"><strong>Product positioning:</strong> The DS124 product page targets professionals and small businesses — "Take command of your most important data." This informed my copy direction away from personal/consumer messaging.</p>
            </div>
            <div class="decision-card">
              <p class="decision-card__response"><strong>Logo rules:</strong> White-on-dark is an approved variation. The registered trademark symbol (&#174;) is always present. "DiskStation" is written as one capitalized word per their naming guidelines.</p>
            </div>
            <div class="decision-card">
              <p class="decision-card__response"><strong>Tone:</strong> Corporate-professional with accessibility — clear feature documentation over aggressive marketing. CTAs are simple: "Learn more" rather than urgency-driven language.</p>
            </div>
          </div>

          <h3 class="reveal">Localization</h3>
          <p class="reveal">The EN/ES pair proves I don't just translate — I adapt design, messaging, and cultural tone while keeping the visual system identical.</p>

          <div class="two-col reveal">
            <figure class="photo-figure mock-watermark">
              <img src="/images/synology/social-square-es.png" alt="Spanish social square — 'Tu trabajo, siempre seguro' with DS124 product photo on dark background" loading="lazy" />
              <figcaption>ES — "Tu trabajo, siempre seguro."</figcaption>
            </figure>
            <figure class="photo-figure mock-watermark">
              <img src="/images/synology/social-square-en.png" alt="English social square — 'Your hard work, always safe' with DS124 product photo on dark background" loading="lazy" />
              <figcaption>EN — "Your hard work, always safe."</figcaption>
            </figure>
          </div>

          <h3 class="reveal">What changed between languages</h3>
          <div class="goals-frustrations-banner reveal">
            <div class="goals-frustrations-banner__inner">
              <div>
                <h3>Visual (Nothing)</h3>
                <ul class="styled-list">
                  <li>Same layout, spacing, and composition</li>
                  <li>Same product image placement and size</li>
                  <li>Same CTA style and position</li>
                  <li>Same typographic hierarchy and weights</li>
                </ul>
              </div>
              <div>
                <h3>Copy (Adapted, Not Translated)</h3>
                <ul class="styled-list">
                  <li>"Tu trabajo" / "Your hard work" — not a literal translation; both feel natural in their language</li>
                  <li>"siempre seguro" / "always safe" — maintains the same emotional weight</li>
                  <li>Subhead rewritten to flow naturally in each language rather than mirroring sentence structure</li>
                  <li>CTA localized: "Mas informacion" / "Learn More"</li>
                </ul>
              </div>
            </div>
          </div>

          <h3 class="reveal">Copy direction</h3>
          <p class="reveal">The initial brief used placeholder copy targeting personal/consumer use: "Your memories, always safe." After researching the DS124's actual product page, I adapted the messaging to match its professional positioning: "Your hard work, always safe" / "Tu trabajo, siempre seguro."</p>

          <h3 class="reveal">Dark background over navy gradient</h3>
          <p class="reveal">The initial mockups used a navy-to-dark-blue gradient. Synology's actual marketing uses deep blacks. I matched the real aesthetic, which also provides stronger contrast for product photography and white headline text.</p>

          <h3 class="reveal">Real product photography</h3>
          <p class="reveal">The initial mockups used a CSS-drawn NAS illustration. I replaced this with the actual DS124 product render, making the designs read as legitimate marketing rather than generic tech mockups.</p>

          <h3 class="reveal">Icon-based feature bullets</h3>
          <p class="reveal">The original web banner used pill-shaped text badges. I replaced these with icon + text pairs (clipboard for access, checkmark for backup, cloud for sync) — more scannable at the small sizes a web banner is typically viewed at.</p>
        </div>
      </section>

      <!-- The Work -->
      <section class="case-section section" id="the-work" aria-labelledby="the-work-heading">
        <div class="container">
          <h2 id="the-work-heading" class="case-section__heading reveal">The Work</h2>

          <h3 class="reveal">01 — Social Square (ES) &middot; 1080&times;1080</h3>
          <p class="reveal">Instagram/Facebook post targeting LATAM Spanish-speaking professionals. Features the DiskStation DS124 product line label, professional-focused headline, and synology.com/es-latam URL.</p>
          <div class="mock-watermark reveal"><img src="/images/synology/social-square-es.png" alt="Full-size Spanish social media square: dark background with Synology logo, 'DiskStation DS124' label, headline 'Tu trabajo, siempre seguro' with 'seguro' in brand blue, body copy about secure private cloud access, DS124 product photo on right, and blue 'Mas informacion' CTA pill button" loading="lazy" /></div>

          <h3 class="reveal">02 — Social Square (EN) &middot; 1080&times;1080</h3>
          <p class="reveal">Same creative, localized for English. Identical layout and visual weight; copy adapted (not literally translated) for natural English. URLs point to synology.com (global) instead of the LATAM subdomain.</p>
          <div class="mock-watermark reveal"><img src="/images/synology/social-square-en.png" alt="Full-size English social media square: identical layout to the Spanish version with headline 'Your hard work, always safe' — 'safe' highlighted in brand blue, adapted English body copy, and 'Learn More' CTA" loading="lazy" /></div>

          <h3 class="reveal">03 — Web Banner (ES) &middot; 1200&times;628</h3>
          <p class="reveal">Landscape format for web, LinkedIn, and link previews. Features the "Almacenamiento que crece contigo" headline with three icon-paired feature callouts: remote access, smart backup, and cloud sync.</p>
          <div class="mock-watermark reveal"><img src="/images/synology/web-banner-es.png" alt="Full-size Spanish web banner in landscape format: Synology logo and 'DiskStation DS124 para tu negocio' label at top, large headline 'Almacenamiento que crece contigo' with 'crece contigo' in brand blue, three feature rows with icons — access, backup, cloud sync — DS124 product render on right, and blue 'Mas informacion' CTA" loading="lazy" /></div>
        </div>
      </section>

      <!-- Reflection -->
      <section class="case-section section" id="reflection" aria-labelledby="reflection-heading">
        <div class="container">
          <h2 id="reflection-heading" class="case-section__heading reveal">Reflection</h2>
          <ul class="styled-list reveal">
            <li><strong>Brand research before design saves rework.</strong> My first instinct was to use the brief's navy gradient and Poppins font, but Synology's actual site revealed a different design language — deeper blacks, Inter typeface, professional messaging. Starting from the brand's reality produced more authentic work.</li>
            <li><strong>Localization is design work, not translation work.</strong> The EN and ES versions look identical at a glance, but achieving that required conscious decisions about line breaks, character counts, and natural phrasing. "Mas informacion" and "Learn More" don't have the same length — the layout has to accommodate both.</li>
            <li><strong>Concept campaigns need clear boundaries.</strong> Watermarking renders as mock-ups and labeling the work as concept protects both my credibility and the brand's — it shows I understand how brand permissions work professionally.</li>
          </ul>

          <PrevNextNav
            prev={{ title: "Our Light Unbound", href: "/our-light-unbound" }}
            next={{ title: "Bb Budget", href: "/offline-budget" }}
          />
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .concept-note {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-style: italic;
  }
  .mock-watermark {
    position: relative;
    display: inline-block;
  }
  .mock-watermark::after {
    content: 'MOCK';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: clamp(2rem, 6vw, 5rem);
    font-weight: 800;
    letter-spacing: 0.3em;
    color: rgba(255, 255, 255, 0.12);
    transform: rotate(-25deg);
    pointer-events: none;
    z-index: 1;
  }
  .synology-hero-assets {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 2rem;
    align-items: center;
  }
  .synology-hero-assets__square {
    width: 100%;
    max-width: 480px;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
  }
  .synology-hero-assets__banner {
    width: 100%;
    max-width: 720px;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
  }
</style>

<script is:inline src="/scripts/scroll-spy.js"></script>
